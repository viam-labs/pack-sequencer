      "model": "viam:pack-sequencer:sequencer"
    }
  ],
  "markdown_link": "README.md",
  "entrypoint": "bin/pack-sequencer",
  "first_run": "",
  "build": {
    "build": "make module.tar.gz",
    "setup": "make setup",
    "path": "module.tar.gz",
    "arch": [
      "linux/amd64",
      "linux/arm64",
      "darwin/arm64"
    ]
  }
}
